# Copy to .env and adjust for your environment. All values below are the
# local-dev (Mac + Docker Desktop) defaults — see README.md for what to use
# on a VPS.

PORT=8083

# Reachable from the *browser* (loads the OnlyOffice JS API).
DOCSERVER_BROWSER_ORIGIN=http://localhost:8082

# Reachable from *inside* the OnlyOffice Docker container, to reach this
# bridge. On a VPS with both containers on the same Docker network, use the
# bridge service's container name instead, e.g. http://onlyoffice-bridge:8083.
BRIDGE_CONTAINER_ORIGIN=http://host.docker.internal:8083

# Puter's API origin as reached from this bridge process.
PUTER_API_ORIGIN=http://api.puter.localhost:4100
